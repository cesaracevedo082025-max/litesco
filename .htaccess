Options -Indexes
RewriteEngine On

# ── Redirigir HTTP → HTTPS ────────────────────────────────────────────────────
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ── Páginas estáticas Next.js (con o sin slash final) ────────────────────────
# Sirve el .html generado por el build, ignorando si existe carpeta con ese nombre
RewriteRule ^blog/?$ /blog.html [L]
RewriteRule ^litis/?$ /litis.html [L]
RewriteRule ^corporativo/?$ /corporativo.html [L]
RewriteRule ^recuperacion/?$ /recuperacion.html [L]
RewriteRule ^faq/?$ /faq.html [L]
RewriteRule ^contacto/?$ /contacto.html [L]
RewriteRule ^sobre-nosotros/?$ /sobre-nosotros.html [L]
RewriteRule ^cms-servicios/?$ /cms-servicios.html [L]

# ── Blog: artículos individuales ──────────────────────────────────────────────
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^blog/([^/]+)/?$ /blog-article.php?slug=$1 [L,QSA]

# ── Servicios: subpáginas individuales por línea ──────────────────────────────
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^litis/([^/]+)/?$ /servicios-articulo.php?linea=litis&slug=$1 [L,QSA]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^corporativo/([^/]+)/?$ /servicios-articulo.php?linea=corporativo&slug=$1 [L,QSA]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^recuperacion/([^/]+)/?$ /servicios-articulo.php?linea=recuperacion&slug=$1 [L,QSA]

# ── Seguridad: bloquear acceso a archivos sensibles ───────────────────────────
<FilesMatch "\.(env|log|sql|bak|sh|htpasswd)$">
    Require all denied
</FilesMatch>

# ── Cache de activos estáticos ────────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/webp                "access plus 1 year"
    ExpiresByType image/png                 "access plus 1 year"
    ExpiresByType image/jpeg                "access plus 1 year"
    ExpiresByType text/css                  "access plus 1 month"
    ExpiresByType application/javascript    "access plus 1 month"
    ExpiresByType font/woff2                "access plus 1 year"
</IfModule>

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>
