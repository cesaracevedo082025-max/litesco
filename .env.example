# Copiar a .env (nunca commitear .env real) y completar con los valores reales.
# IMPORTANTE: NEXT_PUBLIC_META_PIXEL_ID y META_PIXEL_ID deben tener el MISMO valor.
# Next.js solo expone al navegador las variables con prefijo NEXT_PUBLIC_ (se inyectan
# en el build estático con `npm run build` — si cambias el valor, hay que rebuildear).
# PHP (blog-article.php, servicios-articulo.php, send-email-simple.php) lee META_PIXEL_ID.

# Meta Business Suite → Administrador de eventos → tu Pixel
NEXT_PUBLIC_META_PIXEL_ID=
META_PIXEL_ID=

# Meta Business Suite → Administrador de eventos → tu Pixel → Configuración → Conversions API → Generar token de acceso
META_CAPI_ACCESS_TOKEN=

# Opcional: solo mientras pruebas eventos en el panel "Probar eventos" de Meta. Quitar en producción.
META_CAPI_TEST_EVENT_CODE=
